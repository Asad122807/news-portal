<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="620.0" prefWidth="760.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group14.newsportal.Asad.EditArticleController">

    <children>

        <Text fill="RED" layoutX="276.0" layoutY="38.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Edit Article Content">
            <font>
                <Font size="22.0" />
            </font>
        </Text>

        <Text fill="#2f66b3" layoutX="42.0" layoutY="68.0" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-style: italic;" text="Workflow:">
            <font>
                <Font size="18.0" />
            </font>
        </Text>

        <TableView fx:id="articleTableView" layoutX="41.0" layoutY="82.0" prefHeight="220.0" prefWidth="658.0">
            <columns>
                <TableColumn fx:id="eventColumn" prefWidth="95.0" text="Event #" />
                <TableColumn fx:id="descriptionColumn" prefWidth="475.0" text="Description" />
                <TableColumn fx:id="typeColumn" prefWidth="87.0" text="Type" />
            </columns>
        </TableView>

        <Text fill="#2f66b3" layoutX="42.0" layoutY="335.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Write Updated Article Content:">
            <font>
                <Font size="16.0" />
            </font>
        </Text>

        <TextArea fx:id="contentTextArea" layoutX="41.0" layoutY="348.0" prefHeight="180.0" prefWidth="658.0" promptText="Type the edited article content here..." wrapText="true" />

        <Button layoutX="654.0" layoutY="570.0" mnemonicParsing="false" onAction="#backButton" prefHeight="30.0" prefWidth="90.0" text="Back" />

        <Button layoutX="42.0" layoutY="540.0" mnemonicParsing="false" onAction="#saveChangesButton" prefHeight="30.0" prefWidth="120.0" text="Save Changes" />

        <Label fx:id="statusLabel" layoutX="232.0" layoutY="545.0" prefHeight="20.0" prefWidth="350.0" text="Status message" visible="false" />

    </children>
</AnchorPane>
