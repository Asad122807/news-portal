<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group14.newsportal.Asad.AddNewAdController">

    <children>

        <Text fill="RED" layoutX="312.0" layoutY="38.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Add New Advertisement">
            <font>
                <Font size="22.0" />
            </font>
        </Text>

        <Text fill="#2f66b3" layoutX="35.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Enter Advertisement Details:">
            <font>
                <Font size="18.0" />
            </font>
        </Text>

        <Text layoutX="35.0" layoutY="115.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Serial No:" />
        <TextField fx:id="serialNoTextField" layoutX="150.0" layoutY="95.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter serial number" />

        <Text layoutX="35.0" layoutY="160.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Ad Title:" />
        <TextField fx:id="adTitleTextField" layoutX="150.0" layoutY="140.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter ad title" />

        <Text layoutX="35.0" layoutY="205.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Advertiser Name:" />
        <TextField fx:id="advertiserNameTextField" layoutX="150.0" layoutY="185.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter advertiser name" />

        <Text layoutX="430.0" layoutY="115.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Platform:" />
        <TextField fx:id="platformTextField" layoutX="520.0" layoutY="95.0" prefHeight="30.0" prefWidth="220.0" promptText="Facebook / YouTube / Instagram" />

        <Text layoutX="430.0" layoutY="160.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Budget:" />
        <TextField fx:id="budgetTextField" layoutX="520.0" layoutY="140.0" prefHeight="30.0" prefWidth="220.0" promptText="Enter budget amount" />

        <Text layoutX="430.0" layoutY="205.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Status:" />
        <TextField fx:id="statusTextField" layoutX="520.0" layoutY="185.0" prefHeight="30.0" prefWidth="220.0" promptText="Pending / Approved / Active" />

        <Button layoutX="150.0" layoutY="240.0" mnemonicParsing="false" onAction="#addButton" prefHeight="32.0" prefWidth="100.0" text="Add" />
        <Button layoutX="265.0" layoutY="240.0" mnemonicParsing="false" onAction="#clearButton" prefHeight="32.0" prefWidth="100.0" text="Clear" />
        <Button layoutX="786.0" layoutY="604.0" mnemonicParsing="false" onAction="#backButton" prefHeight="32.0" prefWidth="100.0" text="Back" />

        <Label fx:id="statusLabel" layoutX="387.0" layoutY="246.0" prefHeight="63.0" prefWidth="508.0" text="Confirmation message" visible="false" />

        <Text fill="#2f66b3" layoutX="35.0" layoutY="310.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Available Advertisements:">
            <font>
                <Font size="18.0" />
            </font>
        </Text>

        <TableView fx:id="advertisementTableView" layoutX="33.0" layoutY="325.0" prefHeight="270.0" prefWidth="830.0">
            <columns>
                <TableColumn fx:id="serialNoColumn" prefWidth="85.0" text="Serial No" />
                <TableColumn fx:id="adTitleColumn" prefWidth="220.0" text="Ad Title" />
                <TableColumn fx:id="advertiserNameColumn" prefWidth="160.0" text="Advertiser Name" />
                <TableColumn fx:id="platformColumn" prefWidth="120.0" text="Platform" />
                <TableColumn fx:id="budgetColumn" prefWidth="110.0" text="Budget" />
                <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Status" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
