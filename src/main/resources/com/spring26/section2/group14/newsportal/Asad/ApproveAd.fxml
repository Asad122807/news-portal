<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="520.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group14.newsportal.Asad.ApproveAdController">

    <children>

        <Text fill="RED" layoutX="335.0" layoutY="38.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Approve Advertisement">
            <font>
                <Font size="22.0" />
            </font>
        </Text>

        <Text fill="#2f66b3" layoutX="35.0" layoutY="68.0" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-style: italic;" text="Workflow:">
            <font>
                <Font size="18.0" />
            </font>
        </Text>

        <TableView fx:id="advertisementTableView" layoutX="35.0" layoutY="85.0" prefHeight="300.0" prefWidth="830.0">
            <columns>
                <TableColumn fx:id="serialNoColumn" prefWidth="85.0" text="Serial No" />
                <TableColumn fx:id="adTitleColumn" prefWidth="220.0" text="Ad Title" />
                <TableColumn fx:id="advertiserNameColumn" prefWidth="160.0" text="Advertiser Name" />
                <TableColumn fx:id="platformColumn" prefWidth="120.0" text="Platform" />
                <TableColumn fx:id="budgetColumn" prefWidth="110.0" text="Budget" />
                <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Status" />
            </columns>
        </TableView>

        <Button layoutX="786.0" layoutY="474.0" mnemonicParsing="false" onAction="#backButton" prefHeight="32.0" prefWidth="100.0" text="Back" />

        <Button layoutX="35.0" layoutY="394.0" mnemonicParsing="false" onAction="#approveButton" prefHeight="32.0" prefWidth="100.0" text="Approve" />

        <Label fx:id="statusLabel" layoutX="186.0" layoutY="426.0" prefHeight="20.0" prefWidth="596.0" text="Confirmation message" visible="false" />

    </children>
</AnchorPane>
