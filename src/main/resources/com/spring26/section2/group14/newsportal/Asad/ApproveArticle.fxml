<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="520.0" prefWidth="760.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group14.newsportal.Asad.ApproveArticleController">

    <children>

        <Text fill="RED" layoutX="305.0" layoutY="38.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Approve Article">
            <font>
                <Font size="22.0" />
            </font>
        </Text>

        <Text fill="#2f66b3" layoutX="40.0" layoutY="68.0" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-style: italic;" text="Workflow:">
            <font>
                <Font size="18.0" />
            </font>
        </Text>

        <TableView fx:id="articleTableView" layoutX="40.0" layoutY="85.0" prefHeight="320.0" prefWidth="680.0">
            <columns>
                <TableColumn fx:id="serialNoColumn" prefWidth="90.0" text="Serial No" />
                <TableColumn fx:id="articleTitleColumn" prefWidth="280.0" text="Article Title" />
                <TableColumn fx:id="revisedColumn" prefWidth="130.0" text="Revised" />
                <TableColumn fx:id="writerColumn" prefWidth="178.0" text="Writer" />
            </columns>
        </TableView>

        <Button layoutX="656.0" layoutY="476.0" mnemonicParsing="false" onAction="#backButton" prefHeight="30.0" prefWidth="90.0" text="Back" />

        <Button layoutX="40.0" layoutY="420.0" mnemonicParsing="false" onAction="#approveButton" prefHeight="30.0" prefWidth="110.0" text="Approve" />

        <Label fx:id="statusLabel" layoutX="160.0" layoutY="425.0" prefHeight="78.0" prefWidth="486.0" text="Confirmation message" visible="false">
         <font>
            <Font size="16.0" />
         </font></Label>

    </children>
</AnchorPane>
